import React, { useRef, useEffect } = 'react';

const CanvasImageRenderer = ({ imageUrl, width, height }) => {
  const canvasRef = useRef(null);

  useEffect(() = {
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');

    // Cria um novo objeto de imagem virtual
    const image = new Image();
    // Importante para evitar problemas de CORS se a imagem for de outro domínio
    image.crossOrigin = "anonymous";
    image.src = imageUrl;

    // Desenha a imagem no canvas assim que ela carregar
    image.onload = () = {
      // Define as dimensões do canvas com base na imagem, se desejar,
      // ou use as props passadas
      canvas.width = width || image.width;
      canvas.height = height || image.height;

      ctx.drawImage(image, 0, 0, canvas.width, canvas.height);
    };

    // Lida com erros de carregamento, se necessário
    image.onerror = (err) = {
      console.error("Erro ao carregar a imagem:", err);
    };
  }, [imageUrl, width, height]); // Dependências do useEffect

  return <canvas ref={canvasRef} />;
};

export default CanvasImageRenderer;

